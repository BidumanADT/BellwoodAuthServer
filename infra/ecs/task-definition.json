{
  "family": "bellwood-authserver",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [ "FARGATE" ],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::105319843299:role/bellwood-ecs-task-execution-role",
  "taskRoleArn": "arn:aws:iam::105319843299:role/bellwood-authserver-task-role",
  "containerDefinitions": [
    {
      "name": "bellwood-authserver",
      "image": "105319843299.dkr.ecr.us-east-1.amazonaws.com/bellwood-authserver:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "ASPNETCORE_ENVIRONMENT",
          "value": "Alpha"
        },
        {
          "name": "ASPNETCORE_URLS",
          "value": "http://+:8080"
        },
        {
          "name": "ForwardedHeaders__Enabled",
          "value": "true"
        }
      ],
      "secrets": [
        {
          "name": "Jwt__Key",
          "valueFrom": "arn:aws:ssm:us-east-1:105319843299:parameter/bellwood/alpha/authserver/jwt-key"
        },
        {
          "name": "BootstrapAdmin__Email",
          "valueFrom": "arn:aws:ssm:us-east-1:105319843299:parameter/bellwood/alpha/authserver/bootstrap-admin-email"
        },
        {
          "name": "BootstrapAdmin__Password",
          "valueFrom": "arn:aws:ssm:us-east-1:105319843299:parameter/bellwood/alpha/authserver/bootstrap-admin-password"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/bellwood-authserver",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
