{
  "family": "bellwood-authserver",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/EXECUTION_ROLE_NAME",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/TASK_ROLE_NAME",
  "containerDefinitions": [
    {
      "name": "bellwood-authserver",
      "image": "ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/bellwood-authserver:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "ASPNETCORE_ENVIRONMENT",
          "value": "Alpha"
        },
        {
          "name": "ASPNETCORE_URLS",
          "value": "http://+:8080"
        },
        {
          "name": "ForwardedHeaders__Enabled",
          "value": "true"
        }
      ],
      "secrets": [
        {
          "name": "Jwt__Key",
          "valueFrom": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/bellwood/alpha/authserver/jwt-key"
        },
        {
          "name": "BootstrapAdmin__Email",
          "valueFrom": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/bellwood/alpha/authserver/bootstrap-admin-email"
        },
        {
          "name": "BootstrapAdmin__Password",
          "valueFrom": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/bellwood/alpha/authserver/bootstrap-admin-password"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/bellwood-authserver",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:8080/health/live || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 15
      }
    }
  ]
}
